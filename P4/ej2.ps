%!PS-Adobe-3.0

<< /PageSize [842 595] >> setpagedevice

% Carita sonriente amarilla
newpath
200 300 80 0 360 arc
gsave
1 1 0 setrgbcolor fill
grestore
0 setgray 2 setlinewidth stroke

% Ojos
newpath 170 330 8 0 360 arc 0 setgray fill
newpath 230 330 8 0 360 arc 0 setgray fill

% Sonrisa
newpath 200 290 40 210 330 arc 3 setlinewidth stroke

% Parte del texto

