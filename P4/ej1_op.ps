%!PS-Adobe-3.0

<< /PageSize [842 595] >> setpagedevice

% Círculo azul (exterior)
newpath
0.2 0.4 0.8 setrgbcolor
421 297 150 0 360 arc fill 

% Círculo rojo
newpath
1 0 0 setrgbcolor
421 297 120 0 360 arc fill

% Círculo verde
newpath
0.5 0.8 0.4 setrgbcolor
421 297 90 0 360 arc fill

% Círculo morado
newpath
0.8 0.5 1 setrgbcolor
421 297 60 0 360 arc fill

% Círculo amarillo (interior)
newpath
1 1 0 setrgbcolor
421 297 30 0 360 arc fill

% Cara sonriente amarilla
0 setgray             

newpath 411 305 3 0 360 arc fill
newpath 431 305 3 0 360 arc fill

newpath
421 297 15 200 340 arc
2 setlinewidth           
stroke                   

showpage
