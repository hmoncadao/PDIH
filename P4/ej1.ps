%!PS-Adobe-3.0

%Arbol grande
newpath
0.4 0.2 0 setrgbcolor
150 100 moveto
50 0 rlineto
0 200 rlineto
-50 0 rlineto
closepath fill

newpath
0 0.6 0 setrgbcolor
175 350 75 0 360 arc fill
130 380 60 0 360 arc fill
220 380 60 0 360 arc fill
175 430 55 0 360 arc fill

%Circulo verde con borde rojo
newpath
0.6 0.9 0.2 setrgbcolor
300 120 20 0 360 arc
gsave fill grestore
1 0 0 setrgbcolor
2 setlinewidth
stroke

%Arbol pequeno
newpath
0.5 0.25 0 setrgbcolor
400 100 moveto
40 0 rlineto
0 150 rlineto
-40 0 rlineto
closepath fill

newpath
0 0.7 0 setrgbcolor
420 280 60 0 360 arc fill
390 320 50 0 360 arc fill
450 330 45 0 360 arc fill

showpage
